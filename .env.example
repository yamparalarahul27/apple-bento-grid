# =====================================================
# Test-Superteambr-Academy — environment variables
# Copy to .env.local and fill in real values for local dev.
# .env.local is gitignored; never commit it.
# =====================================================

# === Supabase (client-safe — anon key requires RLS in the project) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === JWT signing secret (server-only) ===
# Use a strong random value (e.g. `openssl rand -base64 48`).
# The app refuses to start if this is unset.
JWT_SECRET=

# === Backend Solana signer keypair (server-only) ===
# Path to a JSON-encoded Solana keypair file used to co-sign lesson-completion
# transactions. The file MUST NOT be committed to the repo and MUST be
# readable only by the running process.
BACKEND_SIGNER_KEYPAIR=

# === Solana RPC ===
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
